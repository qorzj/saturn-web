{
  "openapi": "3.0.3",
  "info": {
    "title": "Saturn API",
    "description": "Saturn is a note-taking web application (binfer) built with Python lessweb framework and TypeScript. It provides markdown-based note editing with auto web content grabbing and AI summarization features.",
    "version": "1.0.0",
    "contact": {
      "name": "qorzj",
      "email": "goodhorsezxj@gmail.com"
    },
    "license": {
      "name": "Private"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/public/login": {
      "post": {
        "operationId": "login"
      }
    },
    "/public/login-google-oauth2": {
      "post": {
        "operationId": "login_google_oauth2"
      }
    },
    "/": {
      "get": {
        "operationId": "get_home_page"
      }
    },
    "/api/note/save": {
      "post": {
        "operationId": "post_api_note_save"
      }
    },
    "/api/note/chat": {
      "post": {
        "operationId": "post_api_note_chat"
      }
    },
    "/api/chat-status/{inner_slug}": {
      "get": {
        "operationId": "get_chat_status"
      }
    },
    "/mgr/note": {
      "get": {
        "operationId": "get_all_notes"
      }
    },
    "/mgr/note/{inner_slug}": {
      "get": {
        "operationId": "get_note_by_slug"
      }
    },
    "/public/note/{slug}": {
      "get": {
        "operationId": "get_shared_note_by_slug"
      }
    },
    "/mgr/note/{slug}": {
      "delete": {
        "operationId": "delete_note_by_slug"
      }
    },
    "/api/note/search": {
      "get": {
        "operationId": "search_notes_by_similarity"
      }
    },
    "/api/qiniu/uptoken": {
      "get": {
        "operationId": "get_qiniu_upload_token"
      }
    }
  },
  "components": {
    "schemas": {
      "ChatNoteInput": {
        "properties": {
          "slug": {
            "title": "Slug",
            "type": "string"
          },
          "userPrompt": {
            "title": "Userprompt",
            "type": "string"
          }
        },
        "required": [
          "slug",
          "userPrompt"
        ],
        "title": "ChatNoteInput",
        "type": "object"
      },
      "ChatStatusDto": {
        "properties": {
          "status": {
            "title": "Status",
            "type": "integer"
          },
          "total_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Total Tokens"
          },
          "message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Message"
          }
        },
        "required": [
          "status"
        ],
        "title": "ChatStatusDto",
        "type": "object"
      },
      "GoogleOAuth2LoginRequest": {
        "description": "Google OAuth2登录请求",
        "properties": {
          "code": {
            "title": "Code",
            "type": "string"
          },
          "redirectUri": {
            "title": "Redirecturi",
            "type": "string"
          }
        },
        "required": [
          "code",
          "redirectUri"
        ],
        "title": "GoogleOAuth2LoginRequest",
        "type": "object"
      },
      "ListMgrNoteDto": {
        "properties": {
          "slug": {
            "title": "Slug",
            "type": "string"
          },
          "innerSlug": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Innerslug"
          },
          "contentMd": {
            "title": "Contentmd",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          },
          "contentHtml": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Contenthtml"
          },
          "isShared": {
            "title": "Isshared",
            "type": "integer"
          },
          "createTime": {
            "format": "date-time",
            "title": "Createtime",
            "type": "string"
          },
          "updateTime": {
            "format": "date-time",
            "title": "Updatetime",
            "type": "string"
          },
          "createIp": {
            "title": "Createip",
            "type": "string"
          },
          "updateIp": {
            "title": "Updateip",
            "type": "string"
          },
          "uv": {
            "title": "Uv",
            "type": "integer"
          },
          "embedding": {
            "anyOf": [
              {
                "items": {
                  "type": "number"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Embedding"
          }
        },
        "required": [
          "slug",
          "innerSlug",
          "contentMd",
          "title",
          "contentHtml",
          "isShared",
          "createTime",
          "updateTime",
          "createIp",
          "updateIp",
          "uv"
        ],
        "title": "ListMgrNoteDto",
        "type": "object"
      },
      "ListSearchNoteDto": {
        "properties": {
          "slug": {
            "title": "Slug",
            "type": "string"
          },
          "innerSlug": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Innerslug"
          },
          "title": {
            "title": "Title",
            "type": "string"
          },
          "contentMd": {
            "title": "Contentmd",
            "type": "string"
          },
          "similarity": {
            "title": "Similarity",
            "type": "number"
          },
          "createTime": {
            "format": "date-time",
            "title": "Createtime",
            "type": "string"
          },
          "updateTime": {
            "format": "date-time",
            "title": "Updatetime",
            "type": "string"
          }
        },
        "required": [
          "slug",
          "innerSlug",
          "title",
          "contentMd",
          "similarity",
          "createTime",
          "updateTime"
        ],
        "title": "ListSearchNoteDto",
        "type": "object"
      },
      "LoginRequest": {
        "description": "登录请求",
        "properties": {
          "userName": {
            "title": "Username",
            "type": "string"
          },
          "password": {
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "userName",
          "password"
        ],
        "title": "LoginRequest",
        "type": "object"
      },
      "LoginResponse": {
        "description": "登录响应",
        "properties": {
          "token": {
            "title": "Token",
            "type": "string"
          }
        },
        "required": [
          "token"
        ],
        "title": "LoginResponse",
        "type": "object"
      },
      "SaveNoteInput": {
        "properties": {
          "slug": {
            "title": "Slug",
            "type": "string"
          },
          "contentMd": {
            "title": "Contentmd",
            "type": "string"
          },
          "isShared": {
            "title": "Isshared",
            "type": "integer"
          }
        },
        "required": [
          "slug",
          "contentMd",
          "isShared"
        ],
        "title": "SaveNoteInput",
        "type": "object"
      },
      "SharedNoteDto": {
        "properties": {
          "slug": {
            "title": "Slug",
            "type": "string"
          },
          "contentMd": {
            "title": "Contentmd",
            "type": "string"
          },
          "isShared": {
            "title": "Isshared",
            "type": "integer"
          },
          "createTime": {
            "format": "date-time",
            "title": "Createtime",
            "type": "string"
          },
          "updateTime": {
            "format": "date-time",
            "title": "Updatetime",
            "type": "string"
          }
        },
        "required": [
          "slug",
          "contentMd",
          "isShared",
          "createTime",
          "updateTime"
        ],
        "title": "SharedNoteDto",
        "type": "object"
      }
    }
  },
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication and authorization"
    },
    {
      "name": "Note API",
      "description": "REST API for note operations"
    },
    {
      "name": "Note Management",
      "description": "Management API for note administration"
    },
    {
      "name": "File Upload",
      "description": "File upload token generation and management"
    }
  ]
}